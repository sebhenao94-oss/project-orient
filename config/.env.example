# AWS auth
# Set temporary MFA credentials in PowerShell before running the pipeline.

AWS_REGION=us-east-1

# S3 project folders
S3_BUCKET=msa-summer-2026
S3_INPUT_PREFIX=Team-4/
S3_OUTPUT_PREFIX=Team-4/pipeline_outputs/
S3_RAW_PREFIX=Team-4/raw/

# Optional default for `py -m pipeline.run` when no source-dir argument is
# supplied. Keep building source files in the gitignored repo-local downloads/
# tree so README commands stay portable.
LOCAL_SOURCE_DIR=downloads/Floor_2

# Ingestion image-quality thresholds (defaults shown). Images below the minimum
# sides are flagged and skipped for automatic extraction.
INGESTION_MIN_IMAGE_LONG_SIDE=1000
INGESTION_MIN_IMAGE_SHORT_SIDE=750
INGESTION_MAX_RECOMMENDED_PIXEL_COUNT=100000000

# Database config
DB_HOST=your_postgres_host
DB_NAME=orient_dev
DB_USER=your_user
DB_PASSWORD=your_password
DB_PORT=5432

# LLM config
# Base URL for an OpenAI-compatible inference service.
LLM_BASE_URL=your_vllm_endpoint_here
# Secret bearer credential for the inference service. Never commit a real value.
LLM_API_KEY=your_key_here
# Model identifier exposed by the configured inference endpoint.
LLM_MODEL=your_model_here
# Request timeout for one OpenAI-compatible chat completion.
LLM_TIMEOUT_SECONDS=60
# Bounded transport retry count for transient provider failures.
LLM_MAX_RETRIES=0
# Default bounded concurrency for local batch extraction runners.
LLM_MAX_CONCURRENCY=1
# Completion-token cap sent as max_tokens on each request. 0 omits the field so
# the provider default applies. Dense multi-equipment images need 1024 or more.
LLM_MAX_COMPLETION_TOKENS=2048

# Provider selector. "anthropic" routes through the native Claude Messages API;
# anything else (or unset) uses the OpenAI-compatible client above (vLLM/Qwen,
# hosted OpenAI-SDK-compatible providers). With "anthropic", set LLM_MODEL to a
# Claude id (e.g. claude-haiku-4-5, claude-sonnet-4-6, claude-opus-4-8).
LLM_PROVIDER=anthropic
# Native Anthropic API key (sk-ant-...). Never commit a real value.
ANTHROPIC_API_KEY=your_key_here
# Optional CA bundle path for TLS-intercepting antivirus/proxy environments
# (e.g. Avast SSL scanning). Leave unset to use the default certifi bundle.
LLM_CA_BUNDLE=
# Cache the system prompt as a stable prefix (repeat reads within a run bill at
# ~0.1x). On by default; set to 0/false/no/off to disable.
LLM_PROMPT_CACHE=1
